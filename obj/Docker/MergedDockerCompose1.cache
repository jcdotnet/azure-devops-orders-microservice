name: dockercompose12738144565270361051
services:
  apigateway:
    build:
      context: C:\work\learning\C#\csharp-basics\asp.net\core\eCommerceApp\eCommerce.OrdersService
      dockerfile: OrdersService.ApiGateway/Dockerfile
      args:
        BUILD_CONFIGURATION: Debug
        LAUNCHING_FROM_VS: "true"
      labels:
        com.microsoft.created-by: visual-studio
        com.microsoft.visual-studio.project-name: OrdersService.ApiGateway
      target: base
    entrypoint:
      - dotnet
      - --roll-forward
      - Major
      - /VSTools/DistrolessHelper/DistrolessHelper.dll
      - --wait
    environment:
      ASPNETCORE_LOGGING__CONSOLE__DISABLECOLORS: "true"
      DOTNET_USE_POLLING_FILE_WATCHER: "1"
      NUGET_FALLBACK_PACKAGES: /.nuget/fallbackpackages
    image: apigateway:dev
    labels:
      com.microsoft.visualstudio.debuggee.arguments: ' --additionalProbingPath /.nuget/packages --additionalProbingPath /.nuget/fallbackpackages  "/app/bin/Debug/net10.0/OrdersService.ApiGateway.dll"'
      com.microsoft.visualstudio.debuggee.killprogram: dotnet --roll-forward Major /VSTools/DistrolessHelper/DistrolessHelper.dll --stop dotnet
      com.microsoft.visualstudio.debuggee.program: dotnet
      com.microsoft.visualstudio.debuggee.workingdirectory: /app
    networks:
      ecommerce-network: null
    ports:
      - mode: ingress
        target: 8080
        published: "4000"
        protocol: tcp
    tty: true
    volumes:
      - type: bind
        source: C:\work\learning\C#\csharp-basics\asp.net\core\eCommerceApp\eCommerce.OrdersService\OrdersService.ApiGateway
        target: /app
        bind:
          create_host_path: true
      - type: bind
        source: C:\work\learning\C#\csharp-basics\asp.net\core\eCommerceApp\eCommerce.OrdersService
        target: /src
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\josecarlos\vsdbg\vs2017u5
        target: /remote_debugger
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\josecarlos\.nuget\packages
        target: /.nuget/packages
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages
        target: /.nuget/fallbackpackages
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\josecarlos\AppData\Roaming\ASP.NET\Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\josecarlos\AppData\Roaming\ASP.NET\Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\josecarlos\AppData\Roaming\Microsoft\UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\josecarlos\AppData\Roaming\Microsoft\UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Community\MSBuild\Sdks\Microsoft.Docker.Sdk\tools\linux-x64\net6.0
        target: /VSTools
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Community\Common7\IDE\extensions\Microsoft\managedprojectsystem\HotReload
        target: /HotReloadAgent
        read_only: true
        bind:
          create_host_path: true
  mongodb-container:
    image: mongo:latest
    networks:
      orders-mongodb-network: null
    ports:
      - mode: ingress
        target: 27017
        published: "27017"
        protocol: tcp
    volumes:
      - type: bind
        source: C:\work\learning\C#\csharp-basics\asp.net\core\eCommerceApp\mongodb-init
        target: /docker-entrypoint-initdb.d
        bind:
          create_host_path: true
  mysql-container:
    environment:
      MYSQL_ALLOW_EMPTY_PASSWORD: "yes"
    image: mysql:latest
    networks:
      products-mysql-network: null
    ports:
      - mode: ingress
        target: 3306
        published: "3307"
        protocol: tcp
    volumes:
      - type: bind
        source: C:\work\learning\C#\csharp-basics\asp.net\core\eCommerceApp\mysql-init
        target: /docker-entrypoint-initdb.d
        bind:
          create_host_path: true
  ordersmicroservice.api:
    build:
      context: C:\work\learning\C#\csharp-basics\asp.net\core\eCommerceApp\eCommerce.OrdersService
      dockerfile: OrdersService.API/Dockerfile
      args:
        BUILD_CONFIGURATION: Debug
        LAUNCHING_FROM_VS: "true"
      labels:
        com.microsoft.created-by: visual-studio
        com.microsoft.visual-studio.project-name: OrdersService.API
      target: base
    depends_on:
      mongodb-container:
        condition: service_started
        required: true
    entrypoint:
      - dotnet
      - --roll-forward
      - Major
      - /VSTools/DistrolessHelper/DistrolessHelper.dll
      - --wait
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
      ASPNETCORE_LOGGING__CONSOLE__DISABLECOLORS: "true"
      DOTNET_USE_POLLING_FILE_WATCHER: "1"
      MONGODB_DATABASE: OrdersDatabase
      MONGODB_HOST: mongodb-container
      MONGODB_PORT: "27017"
      NUGET_FALLBACK_PACKAGES: /.nuget/fallbackpackages
      ProductsMicroserviceName: apigateway
      ProductsMicroservicePort: "8080"
      RABBITMQ_HOST: rabbitmq
      RABBITMQ_PASS: password
      RABBITMQ_PORT: "5672"
      RABBITMQ_PRODUCTS_EXCHANGE: products.exchange
      RABBITMQ_USER: user
      REDIS_HOST: redis
      REDIS_PORT: "6379"
      UsersMicroserviceName: apigateway
      UsersMicroservicePort: "8080"
    image: ordersmicroserviceapi:dev
    labels:
      com.microsoft.visualstudio.debuggee.arguments: ' --additionalProbingPath /.nuget/packages --additionalProbingPath /.nuget/fallbackpackages  "/app/bin/Debug/net10.0/OrdersService.API.dll"'
      com.microsoft.visualstudio.debuggee.killprogram: dotnet --roll-forward Major /VSTools/DistrolessHelper/DistrolessHelper.dll --stop dotnet
      com.microsoft.visualstudio.debuggee.program: dotnet
      com.microsoft.visualstudio.debuggee.workingdirectory: /app
    networks:
      ecommerce-network: null
      orders-mongodb-network: null
    ports:
      - mode: ingress
        target: 8080
        published: "5000"
        protocol: tcp
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
        protocol: tcp
    tty: true
    volumes:
      - type: bind
        source: C:\Users\josecarlos\AppData\Roaming\Microsoft\UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\josecarlos\AppData\Roaming\Microsoft\UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\josecarlos\AppData\Roaming\ASP.NET\Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\josecarlos\AppData\Roaming\ASP.NET\Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\work\learning\C#\csharp-basics\asp.net\core\eCommerceApp\eCommerce.OrdersService\OrdersService.API
        target: /app
        bind:
          create_host_path: true
      - type: bind
        source: C:\work\learning\C#\csharp-basics\asp.net\core\eCommerceApp\eCommerce.OrdersService
        target: /src
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\josecarlos\vsdbg\vs2017u5
        target: /remote_debugger
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\josecarlos\.nuget\packages
        target: /.nuget/packages
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages
        target: /.nuget/fallbackpackages
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Community\MSBuild\Sdks\Microsoft.Docker.Sdk\tools\linux-x64\net6.0
        target: /VSTools
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Community\Common7\IDE\extensions\Microsoft\managedprojectsystem\HotReload
        target: /HotReloadAgent
        read_only: true
        bind:
          create_host_path: true
  postgres-container:
    environment:
      POSTGRES_DB: eCommerceUsers
      POSTGRES_PASSWORD: admin
      POSTGRES_USER: postgres
    image: postgres:latest
    networks:
      users-postgres-network: null
    ports:
      - mode: ingress
        target: 5432
        published: "5433"
        protocol: tcp
    volumes:
      - type: bind
        source: C:\work\learning\C#\csharp-basics\asp.net\core\eCommerceApp\postgres-init
        target: /docker-entrypoint-initdb.d
        bind:
          create_host_path: true
  products-microservice:
    depends_on:
      mysql-container:
        condition: service_started
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      MYSQL_DATABASE: ecommerceproductsdatabase
      MYSQL_HOST: mysql-container
      MYSQL_PORT: "3306"
      MYSQL_USERNAME: root
      RABBITMQ_HOST: rabbitmq
      RABBITMQ_PASS: password
      RABBITMQ_PORT: "5672"
      RABBITMQ_PRODUCTS_EXCHANGE: products.exchange
      RABBITMQ_USER: user
    image: products-microservice:latest
    networks:
      ecommerce-network: null
      products-mysql-network: null
    ports:
      - mode: ingress
        target: 8080
        published: "5001"
        protocol: tcp
  rabbitmq:
    environment:
      RABBITMQ_DEFAULT_PASS: password
      RABBITMQ_DEFAULT_USER: user
    image: rabbitmq:management
    networks:
      ecommerce-network: null
    ports:
      - mode: ingress
        target: 5672
        published: "5672"
        protocol: tcp
      - mode: ingress
        target: 15672
        published: "15672"
        protocol: tcp
  redis:
    image: redis:latest
    networks:
      ecommerce-network: null
    ports:
      - mode: ingress
        target: 6379
        published: "6376"
        protocol: tcp
    volumes:
      - type: bind
        source: C:\work\learning\C#\csharp-basics\asp.net\core\eCommerceApp\redis-cache
        target: /data
        bind:
          create_host_path: true
  users-microservice:
    depends_on:
      postgres-container:
        condition: service_started
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      POSTGRES_DATABASE: eCommerceUsers
      POSTGRES_HOST: postgres-container
      POSTGRES_PASSWORD: admin
      POSTGRES_PORT: "5432"
      POSTGRES_USERNAME: postgres
    image: users-microservice:latest
    networks:
      ecommerce-network: null
      users-postgres-network: null
    ports:
      - mode: ingress
        target: 8080
        published: "5002"
        protocol: tcp
networks:
  ecommerce-network:
    name: dockercompose12738144565270361051_ecommerce-network
    driver: bridge
  orders-mongodb-network:
    name: dockercompose12738144565270361051_orders-mongodb-network
    driver: bridge
  products-mysql-network:
    name: dockercompose12738144565270361051_products-mysql-network
    driver: bridge
  users-postgres-network:
    name: dockercompose12738144565270361051_users-postgres-network
    driver: bridge